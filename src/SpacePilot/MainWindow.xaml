                                    <DataGridCheckBoxColumn Header="History" Binding="{Binding HistorySelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                    <DataGridCheckBoxColumn Header="Sessions" Binding="{Binding SessionsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
