                                                     MinHeight="34"
                                                     Padding="9,6"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     AutomationProperties.Name="Protected extensions" />
                                        </StackPanel>
                                        <DataGrid ItemsSource="{Binding ProtectedPaths}" AutomationProperties.Name="Protected paths" IsReadOnly="False">
