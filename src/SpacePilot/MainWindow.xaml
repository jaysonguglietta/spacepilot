                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center" />
                                        <TextBlock Text="Refresh the inventory or clear the search field. Startup enablement is handled through Windows Startup settings."
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextAlignment="Center"
                                                   Margin="0,6,0,14" />
                                        <Button Content="Open Startup settings"
                                                Command="{Binding OpenStartupSettingsCommand}"
                                                HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Recovery}">
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Recovery and receipts"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding QuarantineSummary}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Refresh"
                                        Command="{Binding RefreshRecoveryCommand}"
                                        Margin="0,0,8,0" />
                                <Button Grid.Column="2"
                                        Content="Restore selected"
                                        AutomationProperties.Name="Restore selected quarantine items"
                                        Command="{Binding RestoreSelectedQuarantineCommand}"
                                        Margin="0,0,8,0" />
                                <Button Grid.Column="3"
                                        Content="Purge selected"
                                        AutomationProperties.Name="Purge selected quarantine items"
                                        Command="{Binding PurgeSelectedQuarantineCommand}"
                                        Margin="0,0,8,0" />
                                <Button Grid.Column="4"
                                        Content="Purge all"
                                        AutomationProperties.Name="Purge all quarantine items"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding PurgeAllQuarantineCommand}" />
                            </Grid>

                            <TabControl>
                                <TabItem Header="Quarantine">
                                    <DockPanel Margin="0,12,0,0">
                                        <TextBlock DockPanel.Dock="Bottom"
                                                   Text="{Binding SelectedQuarantineSummary}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="0,12,0,0" />
                                        <DataGrid ItemsSource="{Binding QuarantineEntries}" AutomationProperties.Name="Quarantine entries" IsReadOnly="False">
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="44" />
                                                <DataGridTextColumn Header="Item" Binding="{Binding DisplayName}" Width="220" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="170" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Size" Binding="{Binding SizeBytes, Converter={StaticResource ByteSizeConverter}}" Width="100" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Quarantined" Binding="{Binding QuarantinedLocal, StringFormat={}{0:g}}" Width="140" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Original path" Binding="{Binding OriginalPath}" Width="*" IsReadOnly="True" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </TabItem>
                                <TabItem Header="Receipts">
                                    <DockPanel Margin="0,12,0,0">
                                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                            <Button Content="Export latest receipt"
                                                    AutomationProperties.Name="Export latest cleanup receipt"
                                                    Command="{Binding ExportLatestReceiptCommand}"
                                                    Margin="0,0,10,0" />
                                            <TextBlock Text="Receipts are stored locally as JSON for audit and troubleshooting."
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <DataGrid ItemsSource="{Binding CleanupReceipts}" AutomationProperties.Name="Cleanup receipts" IsReadOnly="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Time" Binding="{Binding TimestampLocal, StringFormat={}{0:g}}" Width="150" />
                                                <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="130" />
                                                <DataGridTextColumn Header="Completed" Binding="{Binding CompletedCount}" Width="90" />
                                                <DataGridTextColumn Header="Size" Binding="{Binding CompletedBytes, Converter={StaticResource ByteSizeConverter}}" Width="110" />
                                                <DataGridTextColumn Header="Free before" Binding="{Binding FreeSpaceBeforeBytes, Converter={StaticResource ByteSizeConverter}}" Width="110" />
                                                <DataGridTextColumn Header="Free after" Binding="{Binding FreeSpaceAfterBytes, Converter={StaticResource ByteSizeConverter}}" Width="110" />
                                                <DataGridTextColumn Header="Quarantine expires" Binding="{Binding QuarantineExpiresLocal, StringFormat={}{0:g}}" Width="150" />
                                                <DataGridTextColumn Header="Restore point" Binding="{Binding RestorePointMessage}" Width="220" />
                                                <DataGridTextColumn Header="Warnings" Binding="{Binding Warnings.Count}" Width="90" />
                                                <DataGridTextColumn Header="Receipt ID" Binding="{Binding Id}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </TabItem>
                            </TabControl>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Settings}">
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,14">
                                <Button Content="Refresh settings checks" Command="{Binding RefreshSettingsCommand}" Margin="0,0,8,0" />
                                <Button Content="Windows Storage settings" Command="{Binding OpenStorageSettingsCommand}" Margin="0,0,8,0" />
                                <Button Content="Disk Cleanup" Command="{Binding OpenDiskCleanupCommand}" Margin="0,0,8,0" />
                                <Button Content="Recycle Bin" Command="{Binding OpenRecycleBinCommand}" />
                            </StackPanel>
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,0,0,16"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Cleanup safeguards"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,10" />
