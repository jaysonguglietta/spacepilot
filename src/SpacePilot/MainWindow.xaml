                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Status}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Activity}">
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Activity log" FontSize="18" FontWeight="SemiBold" />
                                <Button Grid.Column="1"
                                        Content="Clear log"
                                        AutomationProperties.Name="Clear activity log"
                                        Command="{Binding ClearActivityCommand}" />
                            </Grid>
                            <ListBox ItemsSource="{Binding ActivityLog}" AutomationProperties.Name="Activity log" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="145" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimestampLocal, StringFormat={}{0:g}}" Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Level}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Text="{Binding Message}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding BusyText}" Foreground="{StaticResource MutedTextBrush}" />
                    <ProgressBar Grid.Column="1"
                                 Width="160"
                                 Height="10"
                                 AutomationProperties.Name="Operation progress"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
