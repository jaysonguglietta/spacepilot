                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Protected items are skipped by cleanup, large-file review, and duplicate cleanup."
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                    <TextBox Grid.Row="1"
                                             Grid.Column="0"
                                             Text="{Binding NewProtectedPath, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="34"
                                             Padding="9,6"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Path to protect"
                                             AutomationProperties.Name="Path to protect" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding NewProtectedPathReason, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="34"
                                             Padding="9,6"
                                             Margin="8,0,8,0"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Protection reason"
                                             AutomationProperties.Name="Protection reason" />
