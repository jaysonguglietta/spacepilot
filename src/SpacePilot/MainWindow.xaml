                        <TabControl>
                            <TabItem Header="Installed apps">
                                <DockPanel Margin="0,12,0,0">
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding SoftwareSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"
                                                 Padding="9,6"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="Search installed apps"
                                                 AutomationProperties.Name="Search installed apps" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FilteredSoftwareCount, StringFormat={}{0} shown}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,12,0" />
                                        <Button Grid.Column="2" Content="Refresh software" Command="{Binding RefreshSoftwareCommand}" Margin="0,0,8,0" />
                                        <Button Grid.Column="3" Content="Open Apps &amp; Features" AutomationProperties.Name="Open Windows Apps and Features" Command="{Binding OpenAppsSettingsCommand}" />
                                    </Grid>
                                    <Grid>
                                        <DataGrid ItemsSource="{Binding InstalledAppsView}" AutomationProperties.Name="Installed apps" IsReadOnly="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="260" />
                                                <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="180" />
                                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="120" />
                                                <DataGridTextColumn Header="Installed" Binding="{Binding InstallDate}" Width="110" />
                                                <DataGridTextColumn Header="Size" Binding="{Binding EstimatedSizeBytes, Converter={StaticResource ByteSizeConverter}}" Width="90" />
                                                <DataGridTextColumn Header="Uninstall command" Binding="{Binding UninstallCommand}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Border Background="{StaticResource PanelBrush}"
                                                Visibility="{Binding HasNoInstalledApps, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                                                <TextBlock Text="No installed apps to show"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center" />
                                                <TextBlock Text="Refresh the inventory or clear the search field. App removal is handled through Windows Apps &amp; Features."
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextAlignment="Center"
                                                           Margin="0,6,0,14" />
                                                <Button Content="Open Apps &amp; Features"
                                                        Command="{Binding OpenAppsSettingsCommand}"
                                                        HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="WinGet maintenance">
                                <DockPanel Margin="0,12,0,0">
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Package updates"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding WingetSummary}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Check updates" Command="{Binding RefreshWingetCommand}" Margin="0,0,8,0" />
                                        <Button Grid.Column="2" Content="Update selected" AutomationProperties.Name="Update selected WinGet packages" Style="{StaticResource PrimaryButton}" Command="{Binding UpgradeSelectedPackagesCommand}" Margin="0,0,8,0" />
                                        <Button Grid.Column="3" Content="Export list" Command="{Binding ExportWingetPackagesCommand}" Margin="0,0,8,0" />
                                        <Button Grid.Column="4" Content="Import list" Command="{Binding ImportWingetPackagesCommand}" />
                                    </Grid>
                                    <DataGrid ItemsSource="{Binding WingetPackages}" AutomationProperties.Name="WinGet package updates" IsReadOnly="False">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="44" />
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="240" IsReadOnly="True" />
                                            <DataGridTextColumn Header="Package ID" Binding="{Binding Id}" Width="220" IsReadOnly="True" />
                                            <DataGridTextColumn Header="Installed" Binding="{Binding Version}" Width="110" IsReadOnly="True" />
                                            <DataGridTextColumn Header="Available" Binding="{Binding AvailableVersion}" Width="110" IsReadOnly="True" />
                                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" IsReadOnly="True" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Startup}">
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding StartupSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="34"
                                         Padding="9,6"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Search startup apps"
                                         AutomationProperties.Name="Search startup apps" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FilteredStartupCount, StringFormat={}{0} shown}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,12,0" />
                                <Button Grid.Column="2" Content="Refresh startup apps" Command="{Binding RefreshStartupCommand}" Margin="0,0,8,0" />
                                <Button Grid.Column="3" Content="Open Startup settings" Command="{Binding OpenStartupSettingsCommand}" />
                            </Grid>
                            <Grid>
                                <DataGrid ItemsSource="{Binding StartupEntriesView}" AutomationProperties.Name="Startup entries" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" />
                                        <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="110" />
                                        <DataGridTextColumn Header="Source" Binding="{Binding SourceType}" Width="130" />
                                        <DataGridTextColumn Header="Impact" Binding="{Binding Impact}" Width="90" />
                                        <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="250" />
                                        <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="*" />
