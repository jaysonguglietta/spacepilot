<Window x:Class="SpacePilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SpacePilot.Converters"
        Title="SpacePilot"
        Width="1220"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource AppBackgroundBrush}"
        AutomationProperties.Name="SpacePilot"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ByteSizeConverter x:Key="ByteSizeConverter" />
        <converters:SectionVisibilityConverter x:Key="SectionVisibilityConverter" />
        <converters:RiskBrushConverter x:Key="RiskBrushConverter" />
        <converters:StatusBrushConverter x:Key="StatusBrushConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="18,22,18,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="40"
                            Height="40"
                            CornerRadius="10"
                            Background="#07111D"
                            BorderBrush="#1F8FEA"
                            BorderThickness="1">
                        <Image Source="Assets/AppIcon.ico"
                               Width="32"
                               Height="32"
                               AutomationProperties.Name="SpacePilot app icon"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="SpacePilot"
                                   Foreground="#FFFFFFFF"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Local cleanup toolkit"
                                   Foreground="#9DA8B6"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <StackPanel DockPanel.Dock="Bottom" Margin="18">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#B7C2D0"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel>
                    <Button Content="Health"
                            AutomationProperties.Name="Open Health section"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="Health"
                            Style="{StaticResource SidebarButton}" />
                    <Button Content="Cleaner"
                            AutomationProperties.Name="Open Cleaner section"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="Cleaner"
                            Style="{StaticResource SidebarButton}" />
                    <Button Content="Storage"
                            AutomationProperties.Name="Open Storage section"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="Storage"
                            Style="{StaticResource SidebarButton}" />
                    <Button Content="Browsers"
                            AutomationProperties.Name="Open Browsers section"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="Browsers"
                            Style="{StaticResource SidebarButton}" />
                    <Button Content="Software"
                            AutomationProperties.Name="Open Software section"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="Software"
                            Style="{StaticResource SidebarButton}" />
                    <Button Content="Startup"
                            AutomationProperties.Name="Open Startup section"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="Startup"
                            Style="{StaticResource SidebarButton}" />
                    <Button Content="Recovery"
                            AutomationProperties.Name="Open Recovery section"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="Recovery"
                            Style="{StaticResource SidebarButton}" />
                    <Button Content="Settings"
                            AutomationProperties.Name="Open Settings section"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="Settings"
                            Style="{StaticResource SidebarButton}" />
                    <Button Content="Activity"
                            AutomationProperties.Name="Open Activity section"
                            Command="{Binding SelectSectionCommand}"
                            CommandParameter="Activity"
                            Style="{StaticResource SidebarButton}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding SelectedSectionTitle}"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedSectionSubtitle}"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Restore point"
                            AutomationProperties.Name="Create Windows restore point"
                            Margin="0,0,8,0"
                            Command="{Binding CreateRestorePointCommand}" />
                    <Button Content="Scan"
                            AutomationProperties.Name="Run cleanup scan"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ScanCommand}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Health}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#EAF4FF"
                            BorderBrush="#B7D8F6"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,16"
                            Visibility="{Binding ShowFirstRun, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Safety-first cleanup"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0">
                                    <Run Text="SpacePilot scans first, shows every candidate, skips unsafe paths, and never edits the registry automatically." />
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Got it"
                                    AutomationProperties.Name="Dismiss first-run safety note"
                                    Command="{Binding DismissFirstRunCommand}"
                                    VerticalAlignment="Center"
                                    Margin="16,0,0,0" />
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Cleanup estimate" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding TotalScannedBytes, Converter={StaticResource ByteSizeConverter}}" FontSize="26" FontWeight="SemiBold" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding LastScanText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Selected items" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding TotalSelectedBytes, Converter={StaticResource ByteSizeConverter}}" FontSize="26" FontWeight="SemiBold" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding SelectedPreviewSummary}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Recovery queue" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding QuarantineBytes, Converter={StaticResource ByteSizeConverter}}" FontSize="26" FontWeight="SemiBold" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding QuarantineSummary}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Recommended reclaim plan" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <ItemsControl ItemsSource="{Binding ReclaimPlan}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Priority}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Area}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Recommendation}" Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding EstimatedBytes, Converter={StaticResource ByteSizeConverter}}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding Risk}" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Settings health" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,12" />
                                <ItemsControl ItemsSource="{Binding SettingsChecks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Fill="{Binding Status, Converter={StaticResource StatusBrushConverter}}" Width="8" Height="8" VerticalAlignment="Top" Margin="0,6,0,0" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Next actions" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <Button Content="Run cleanup scan" Command="{Binding ScanCommand}" Margin="0,0,0,8" />
                                <Button Content="Find large files" Command="{Binding SelectSectionCommand}" CommandParameter="Storage" Margin="0,0,0,8" />
                                <Button Content="Review recovery queue" Command="{Binding SelectSectionCommand}" CommandParameter="Recovery" Margin="0,0,0,8" />
                                <Button Content="Review software" Command="{Binding SelectSectionCommand}" CommandParameter="Software" Margin="0,0,0,8" />
                                <Button Content="Review startup apps" Command="{Binding SelectSectionCommand}" CommandParameter="Startup" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Cleaner}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,14,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                                <Button Content="Clean selected items"
                                        AutomationProperties.Name="Clean selected cleanup items"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding CleanCommand}"
                                        Margin="0,0,0,8" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}">
                                    <Run Text="Selected estimate: " />
                                    <Run Text="{Binding TotalSelectedBytes, Converter={StaticResource ByteSizeConverter}}" />
                                </TextBlock>
                                <TextBlock Text="{Binding CleanReadinessMessage}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CleanupCategories}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              AutomationProperties.Name="{Binding Name}"
                                                              VerticalAlignment="Top"
                                                              Margin="0,4,10,0" />
                                                    <StackPanel Grid.Column="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                            <Border Grid.Column="1"
                                                                    Background="{Binding Risk, Converter={StaticResource RiskBrushConverter}}"
                                                                    Padding="7,2">
                                                                <TextBlock Text="{Binding Risk}" Foreground="#FFFFFFFF" FontSize="11" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,4" />
                                                        <TextBlock Foreground="{StaticResource MutedTextBrush}">
                                                            <Run Text="{Binding CandidateCount}" />
                                                            <Run Text=" items, " />
                                                            <Run Text="{Binding LastScanBytes, Converter={StaticResource ByteSizeConverter}}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Cleanup review"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedPreviewSummary}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Select all"
                                            AutomationProperties.Name="Select all cleanup candidates"
                                            Command="{Binding SelectAllPreviewCommand}"
                                            Margin="0,0,8,0" />
                                    <Button Content="Select visible"
                                            AutomationProperties.Name="Select visible cleanup candidates"
                                            Command="{Binding SelectVisiblePreviewCommand}"
                                            Margin="0,0,8,0" />
                                    <Button Content="Clear"
                                            AutomationProperties.Name="Clear cleanup candidate selection"
                                            Command="{Binding ClearPreviewSelectionCommand}" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding CleanerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="34"
                                         Padding="9,6"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Search cleanup items"
                                         AutomationProperties.Name="Search cleanup items" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding CategoryFilterOptions}"
                                          SelectedItem="{Binding SelectedCategoryFilter}"
                                          MinHeight="34"
                                          Margin="8,0,0,0"
                                          VerticalContentAlignment="Center"
                                          ToolTip="Filter cleanup category"
                                          AutomationProperties.Name="Filter cleanup category" />
                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding RiskFilterOptions}"
                                          SelectedItem="{Binding SelectedRiskFilter}"
                                          MinHeight="34"
                                          Margin="8,0,0,0"
                                          VerticalContentAlignment="Center"
                                          ToolTip="Filter cleanup risk"
                                          AutomationProperties.Name="Filter cleanup risk" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding FilteredPreviewCount, StringFormat={}{0} shown}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <DataGrid ItemsSource="{Binding PreviewEntriesView}"
                                          AutomationProperties.Name="Cleanup candidates"
                                          IsReadOnly="False">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="44" />
                                        <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="150" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Item" Binding="{Binding DisplayName}" Width="220" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Risk" Binding="{Binding Risk}" Width="80" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding SizeBytes, Converter={StaticResource ByteSizeConverter}}" Width="90" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Modified" Binding="{Binding LastModifiedLocal, StringFormat={}{0:g}}" Width="140" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Background="{StaticResource PanelBrush}"
                                        Visibility="{Binding HasNoPreviewEntries, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                                        <TextBlock Text="No cleanup items to show"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center" />
                                        <TextBlock Text="Run a scan, adjust filters, or enable more cleanup categories to review candidates."
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextAlignment="Center"
                                                   Margin="0,6,0,14" />
                                        <Button Content="Run scan"
                                                AutomationProperties.Name="Run cleanup scan from empty state"
                                                Command="{Binding ScanCommand}"
                                                Style="{StaticResource PrimaryButton}"
                                                HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionVisibilityConverter}, ConverterParameter=Storage}">
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Storage cleanup"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding StorageSummary}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="Large MB"
                                           VerticalAlignment="Center"
                                           Margin="12,0,6,0"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding LargeFileMinimumMb, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="34"
                                         Padding="8,6"
                                         VerticalContentAlignment="Center"
                                         AutomationProperties.Name="Large file minimum megabytes" />
                                <TextBlock Grid.Column="3"
                                           Text="Duplicate MB"
                                           VerticalAlignment="Center"
                                           Margin="12,0,6,0"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Grid.Column="4"
                                         Text="{Binding DuplicateMinimumMb, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="34"
                                         Padding="8,6"
                                         VerticalContentAlignment="Center"
                                         AutomationProperties.Name="Duplicate file minimum megabytes" />
                                <Button Grid.Column="5"
                                        Content="Scan large files"
                                        AutomationProperties.Name="Scan large files"
                                        Command="{Binding ScanLargeFilesCommand}"
                                        Margin="12,0,8,0" />
                                <Button Grid.Column="6"
                                        Content="Find duplicates"
                                        AutomationProperties.Name="Find duplicate files"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ScanDuplicatesCommand}" />
                            </Grid>

                            <TabControl>
                                <TabItem Header="Storage map">
                                    <Grid Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                            <Button Content="Map storage"
                                                    Command="{Binding ScanStorageMapCommand}"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Margin="0,0,10,0" />
                                            <TextBlock Text="{Binding StorageMapSummary}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <DockPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock DockPanel.Dock="Top" Text="Top folders" FontWeight="SemiBold" Margin="0,0,0,8" />
                                                <DataGrid ItemsSource="{Binding FolderUsage}" AutomationProperties.Name="Top storage folders" IsReadOnly="True">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Folder" Binding="{Binding Name}" Width="180" />
                                                        <DataGridTextColumn Header="Size" Binding="{Binding SizeBytes, Converter={StaticResource ByteSizeConverter}}" Width="100" />
                                                        <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" Width="80" />
                                                        <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="260" />
                                                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </DockPanel>
                                            <DockPanel Grid.Column="1">
                                                <TextBlock DockPanel.Dock="Top" Text="File types" FontWeight="SemiBold" Margin="0,0,0,8" />
                                                <DataGrid ItemsSource="{Binding FileTypeUsage}" AutomationProperties.Name="Storage by file type" IsReadOnly="True">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Type" Binding="{Binding Extension}" Width="80" />
                                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                                                        <DataGridTextColumn Header="Size" Binding="{Binding SizeBytes, Converter={StaticResource ByteSizeConverter}}" Width="100" />
                                                        <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" Width="*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </DockPanel>
                                        </Grid>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Large files">
                                    <DockPanel Margin="0,12,0,0">
                                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Content="Quarantine selected large files"
                                                    AutomationProperties.Name="Quarantine selected large files"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding QuarantineSelectedLargeFilesCommand}"
                                                    Margin="0,0,10,0" />
                                            <TextBlock Text="{Binding LargeFileSelectionSummary}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <DataGrid ItemsSource="{Binding LargeFiles}" AutomationProperties.Name="Large files" IsReadOnly="False">
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="44" />
                                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="230" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Size" Binding="{Binding SizeBytes, Converter={StaticResource ByteSizeConverter}}" Width="100" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Modified" Binding="{Binding LastModifiedLocal, StringFormat={}{0:g}}" Width="140" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="260" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" IsReadOnly="True" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </TabItem>
                                <TabItem Header="Duplicates">
                                    <DockPanel Margin="0,12,0,0">
                                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Content="Quarantine selected duplicates"
                                                    AutomationProperties.Name="Quarantine selected duplicate files"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Command="{Binding QuarantineSelectedDuplicatesCommand}"
                                                    Margin="0,0,10,0" />
                                            <TextBlock Text="{Binding DuplicateSelectionSummary}"
                                                       Foreground="{StaticResource MutedTextBrush}"
