                                                  IsChecked="{Binding ConfirmBeforeCleanup, Mode=TwoWay}"
                                                  Margin="0,0,0,8" />
                                        <CheckBox Content="Recommend a restore point for medium-risk cleanup"
                                                  IsChecked="{Binding RemindRestorePointBeforeCleanup, Mode=TwoWay}"
                                                  Margin="0,0,0,8" />
                                        <CheckBox Content="Move cleanup items to quarantine before purge"
                                                  IsChecked="{Binding UseQuarantine, Mode=TwoWay}"
                                                  Margin="0,0,0,8" />
                                        <CheckBox Content="Select medium-risk categories by default"
                                                  IsChecked="{Binding SelectMediumRiskByDefault, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                                        <TextBlock Text="Current policy"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,10" />
                                        <TextBlock Text="{Binding SafetyPreferenceSummary}"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding SelectedCategorySummary}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding LastCleanupText}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="0,6,0,0" />
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Retention days"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding QuarantineRetentionDays, UpdateSourceTrigger=PropertyChanged}"
                                                     MinHeight="30"
                                                     Padding="7,4"
                                                     AutomationProperties.Name="Quarantine retention days" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,0,0,16"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Scheduled scans"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ScheduledScanStatusText}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Enable weekly reminder"
                                            Command="{Binding EnableWeeklyScanReminderCommand}"
                                            Margin="12,0,8,0"
                                            VerticalAlignment="Center" />
                                    <Button Grid.Column="2"
                                            Content="Disable"
                                            Command="{Binding DisableWeeklyScanReminderCommand}"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,0,0,16"
                                    Margin="0,0,0,16">
